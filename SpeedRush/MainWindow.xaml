<Window x:Class="SpeedRush.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Speed Rush" Height="450" Width="350">
    <Canvas Background="Black">
        <Rectangle x:Name="Player" Fill="White" Width="30" Height="30" Canvas.Left="150" Canvas.Top="350"/>
        <Rectangle x:Name="Obstacle" Fill="Red" Width="30" Height="30" Canvas.Left="150" Canvas.Top="0"/>
    </Canvas>
</Window>